# Copy this file to .env and fill in your credentials.
# Never commit .env (it's in .gitignore).

# --- Required ---

# Anthropic API key — used if a Python script needs Claude (orchestration is
# done by the agent runtime itself which has its own auth).
ANTHROPIC_API_KEY=sk-ant-...

# --- Strongly recommended (free tiers cover most testing) ---

# Pappers API — direct website / email / phone / dirigeants for FR companies.
# Free tier = 100 requests / day. https://www.pappers.fr/api
PAPPERS_API_KEY=

# Brave Search API — stable, fast replacement for DuckDuckGo.
# Free tier = 2 000 requests / month. https://api-dashboard.search.brave.com/
BRAVE_SEARCH_API_KEY=

# Serper.dev — Google search via REST API. PRIORITY backend in 2026 because
# Google CSE is closed to new customers and Brave's free quota is small.
# Free tier: 2,500 queries one-shot at signup (no card required).
# Setup (1 min): https://serper.dev → sign up with Google → copy API key
SERPER_API_KEY=

# Dropcontact — French B2B contact enrichment. (firstname, lastname, company)
# → verified email + phone. 100% GDPR. Free tier: 50 credits at signup (no card).
# Setup (3 min): https://www.dropcontact.com/signup → Dashboard → API → copy key
DROPCONTACT_API_KEY=

# HERE Maps Geocoding/Search — 250 000 free transactions/month. Returns the
# REAL listed phone for places (where Serper /places does not). The biggest
# free win for company_phone coverage. Sign up (10 min, no card):
#   https://platform.here.com → Apps → Create REST app → copy API key
HERE_MAPS_API_KEY=

# Hunter.io — email finder + verifier. Free: 50 credits/month. Used as 2nd
# source after Dropcontact in the email waterfall.
# Setup: https://hunter.io/users/sign_up → Dashboard → API → copy key
HUNTER_API_KEY=

# Datagma — French B2B specialist (95% accuracy on FR, vs ~85% US tools).
# Free: 50 credits + 160 API matches (~5 mobile lookups, 50+ emails).
# Setup: https://app.datagma.com → sign up → Settings → API → copy token
DATAGMA_API_KEY=

# BetterContact — waterfall over 20+ providers (Apollo, Kaspr, Lusha, Hunter,
# ZoomInfo, ContactOut, etc.). PAY-PER-VALID: 50 free credits only deducted
# when a verified contact is returned. Used as last-resort in the cascade.
# Setup: https://app.bettercontact.rocks/sign-up → Settings → API → copy key
BETTERCONTACT_API_KEY=

# France Travail (ex-Pôle Emploi) — 100% FREE official partner API.
# Returns active job offers per SIRET → "boîte qui recrute" = boîte en
# croissance = budget formation/IA. THE most underused signal in FR B2B.
# Setup (10 min): https://francetravail.io/data → sign up (no card) → create
# app → request access to "Offres d'emploi v2" → copy client_id + secret.
FRANCETRAVAIL_CLIENT_ID=
FRANCETRAVAIL_CLIENT_SECRET=

# Google Custom Search Engine (CSE) — LEGACY, closed to new customers in 2025.
# Only useful if you already had a key. New users → use SERPER_API_KEY instead.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# --- Optional CRM sync ---

# HubSpot Free CRM Private App token. Sync leads as Contacts+Companies+Notes.
# Get one in <5min: https://www.hubspot.com/products/get-started → Settings →
# Integrations → Private Apps → Create. Scopes: crm.objects.contacts.write,
# crm.objects.companies.write, crm.objects.notes.write (+ matching .read).
HUBSPOT_ACCESS_TOKEN=

# --- Optional (Google Sheets export, filled by setup_wizard.py) ---

GOOGLE_SERVICE_ACCOUNT_JSON=
DEFAULT_SHEET_ID=
