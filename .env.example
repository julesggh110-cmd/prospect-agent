# Copy this file to .env and fill in your credentials.
# Never commit .env (it's in .gitignore).

# --- Required ---

# Anthropic API key — used if a Python script needs Claude (orchestration is
# done by the agent runtime itself which has its own auth).
ANTHROPIC_API_KEY=sk-ant-...

# --- Strongly recommended (free tiers cover most testing) ---

# Pappers API — direct website / email / phone / dirigeants for FR companies.
# Free tier = 100 requests / day. https://www.pappers.fr/api
PAPPERS_API_KEY=

# Brave Search API — stable, fast replacement for DuckDuckGo.
# Free tier = 2 000 requests / month. https://api-dashboard.search.brave.com/
BRAVE_SEARCH_API_KEY=

# Google Custom Search Engine (CSE) — best backend for LinkedIn / Insta
# profile discovery. 100 free queries / day (= ~3000 / month).
# Setup (5 min):
#   1. https://console.cloud.google.com/apis/credentials → Create API key
#   2. https://console.cloud.google.com/apis/library/customsearch.googleapis.com → Enable
#   3. https://programmablesearchengine.google.com/controlpanel/create
#      → "Search the entire web" = Yes → copy the Search engine ID
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# --- Optional CRM sync ---

# HubSpot Free CRM Private App token. Sync leads as Contacts+Companies+Notes.
# Get one in <5min: https://www.hubspot.com/products/get-started → Settings →
# Integrations → Private Apps → Create. Scopes: crm.objects.contacts.write,
# crm.objects.companies.write, crm.objects.notes.write (+ matching .read).
HUBSPOT_ACCESS_TOKEN=

# --- Optional (Google Sheets export, filled by setup_wizard.py) ---

GOOGLE_SERVICE_ACCOUNT_JSON=
DEFAULT_SHEET_ID=
