# Copy this file to .env and fill in your credentials.
# Never commit .env (it's in .gitignore).

# --- Required ---

# Anthropic API key — used if a Python script needs Claude (orchestration is
# done by the agent runtime itself which has its own auth).
ANTHROPIC_API_KEY=sk-ant-...

# --- Strongly recommended (free tiers cover most testing) ---

# Pappers API — direct website / email / phone / dirigeants for FR companies.
# Free tier = 100 requests / day. https://www.pappers.fr/api
PAPPERS_API_KEY=

# Brave Search API — stable, fast replacement for DuckDuckGo.
# Free tier = 2 000 requests / month. https://api-dashboard.search.brave.com/
BRAVE_SEARCH_API_KEY=

# Serper.dev — Google search via REST API. PRIORITY backend in 2026 because
# Google CSE is closed to new customers and Brave's free quota is small.
# Free tier: 2,500 queries one-shot at signup (no card required).
# Setup (1 min): https://serper.dev → sign up with Google → copy API key
SERPER_API_KEY=

# Dropcontact — French B2B contact enrichment. (firstname, lastname, company)
# → verified email + phone. 100% GDPR. Free tier: 50 credits at signup (no card).
# Setup (3 min): https://www.dropcontact.com/signup → Dashboard → API → copy key
DROPCONTACT_API_KEY=

# Google Custom Search Engine (CSE) — LEGACY, closed to new customers in 2025.
# Only useful if you already had a key. New users → use SERPER_API_KEY instead.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# --- Optional CRM sync ---

# HubSpot Free CRM Private App token. Sync leads as Contacts+Companies+Notes.
# Get one in <5min: https://www.hubspot.com/products/get-started → Settings →
# Integrations → Private Apps → Create. Scopes: crm.objects.contacts.write,
# crm.objects.companies.write, crm.objects.notes.write (+ matching .read).
HUBSPOT_ACCESS_TOKEN=

# --- Optional (Google Sheets export, filled by setup_wizard.py) ---

GOOGLE_SERVICE_ACCOUNT_JSON=
DEFAULT_SHEET_ID=
